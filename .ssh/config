Include ~/dotfiles/.ssh/hosts/current-os/*.conf
Include ~/dotfiles/.ssh/hosts/*.conf
IgnoreUnknown UseKeychain

Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
  IdentityFile ~/.ssh/id_rsa
  StrictHostKeyChecking accept-new
  ForwardAgent yes 
  PermitLocalCommand true
  ServerAliveInterval 30 
  ServerAliveCountMax 3
  # ControlPath ~/.ssh/controlmasters/%l_%r@%h:%p
  KexAlgorithms +diffie-hellman-group1-sha1
  PreferredAuthentications publickey

  # Передаём тип терминала через LC_TERMINAL (LC_* разрешены в sshd)
  SetEnv COLORTERM=truecolor
  SendEnv COLORTERM

  SetEnv LC_COLORTERM=truecolor
  SendEnv LC_COLORTERM

  SetEnv LC_TERMINAL=ghostty
  SendEnv LC_TERMINAL
  #StrictHostKeyChecking accept-new
  #ForwardAgent yes 
  #IdentityFile ~/.ssh/id_rsa
  #PermitLocalCommand true
  ControlMaster auto
  ControlPersist 600
  #ControlPath ~/.ssh/controlmasters/%l_%r@%h:%p
  #KexAlgorithms +diffie-hellman-group1-sha1
  # PreferredAuthentications publickey
Host *
  UseKeychain yes
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_ed25519
  IdentityFile ~/.ssh/id_rsa
