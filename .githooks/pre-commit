#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

allowed='^\.gnupg/(\.gitignore|common\.conf|gpg-agent\.conf|gpg-agent\.macos\.conf|gpg\.conf|dirmngr\.conf|scdaemon\.conf)$'

staged_paths="$(git diff --cached --name-only --diff-filter=ACMR)"

blocked=""
while IFS= read -r path; do
  [ -z "$path" ] && continue

  case "$path" in
    .gnupg/*)
      if [[ ! "$path" =~ $allowed ]]; then
        blocked+="$path"$'\n'
      fi
      ;;
  esac
done <<< "$staged_paths"

if [ -n "$blocked" ]; then
  echo "ERROR: refusing to commit sensitive .gnupg files:"
  printf '%s' "$blocked"
  echo
  echo "Allowed .gnupg files:"
  echo "  .gnupg/.gitignore"
  echo "  .gnupg/common.conf"
  echo "  .gnupg/gpg-agent.conf"
  echo "  .gnupg/gpg.conf"
  echo "  .gnupg/dirmngr.conf"
  echo "  .gnupg/scdaemon.conf"
  echo
  echo "If this is intentional, move secrets out of git first."
  exit 1
fi

if command -v mise >/dev/null 2>&1 && gitleaks_path="$(mise which gitleaks 2>/dev/null)"; then
  gitleaks_cmd=("$gitleaks_path")
elif command -v gitleaks >/dev/null 2>&1; then
  gitleaks_cmd=(gitleaks)
else
  echo "ERROR: gitleaks is required for pre-commit secret scanning."
  echo "Run 'make' or 'mise install gitleaks' and try again."
  exit 1
fi

"${gitleaks_cmd[@]}" git --staged --no-banner --redact --log-level warn
