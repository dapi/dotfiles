keybind = super+shift+r=reload_config
keybind = cmd+shift+left=previous_tab
keybind = cmd+shift+right=next_tab

font-family = Driod Sans Mono Dotted for Powerline
font-size = 17
font-thicken = false

minimum-contrast = 0

# Light themes: Catppuccin Latte, Solarized Light, Tokyo Night Light,
#   Rose Pine Dawn, GitHub Light, Gruvbox Light
theme = light:Gruvbox Light,dark:Dapi

# Appearance and Tabs
# macos-titlebarZstyle = tabs
macos-titlebar-style = transparent
macos-option-as-alt = true

mouse-hide-while-typing = true

window-padding-balance = true
window-save-state = always
fullscreen = true
# macos-non-native-fullscreen = true

shell-integration = zsh
shell-integration-features = cursor,sudo,title

quit-after-last-window-closed=true

clipboard-read=allow
clipboard-write=allow
copy-on-select=false
# copy-on-select = clipboard
keybind = shift+enter=text:\x1b\r

# Fix ctrl+key shortcuts when Russian keyboard layout is active.
# physical: binds to the physical key position regardless of layout.
keybind = physical:ctrl+c=text:\x03
keybind = physical:ctrl+d=text:\x04
keybind = physical:ctrl+z=text:\x1a
keybind = physical:ctrl+a=text:\x01
keybind = physical:ctrl+e=text:\x05
keybind = physical:ctrl+k=text:\x0b
keybind = physical:ctrl+l=text:\x0c
keybind = physical:ctrl+r=text:\x12
keybind = physical:ctrl+u=text:\x15
keybind = physical:ctrl+w=text:\x17
